// ----------------------------------------------------------------------
// Diagram 4: Remedies Overview
// ----------------------------------------------------------------------
function RemediesDiagram() {
  return (
    <div className="space-y-8 animate-in fade-in duration-500">
      <div className="text-center max-w-2xl mx-auto mb-8">
        <h2 className="text-2xl font-bold text-slate-900 mb-3">Remedies for Misappropriation</h2>
        <p className="text-slate-600">
          When secrecy is breached, courts utilize a blend of equitable and monetary remedies to stop the bleeding, restore the owner, and punish severe misconduct.
        </p>
      </div>

      <div className="flex flex-col md:flex-row gap-6 max-w-5xl mx-auto">
        
        {/* Equitable Relief */}
        <div className="flex-1 bg-white border-2 border-slate-200 rounded-2xl overflow-hidden shadow-sm flex flex-col">
          <div className="bg-slate-100 p-4 border-b border-slate-200 flex items-center gap-3">
            <Scale className="text-slate-700" size={24} />
            <h3 className="font-bold text-lg text-slate-800">1. Injunctive Relief</h3>
          </div>
          <div className="p-5 space-y-4 flex-1">
            <div className="border-l-4 border-blue-500 pl-4 py-1">
              <h4 className="font-bold text-slate-800">Preliminary Injunction</h4>
              <p className="text-sm text-slate-600 mt-1">Stops the bleeding immediately during litigation. Requires showing irreparable harm (loss of exclusivity).</p>
            </div>
            <div className="border-l-4 border-indigo-500 pl-4 py-1">
              <h4 className="font-bold text-slate-800">Permanent Injunction</h4>
              <p className="text-sm text-slate-600 mt-1">Issued post-trial. Can include a "Head Start" injunction (banning use for the time it would have taken to develop lawfully).</p>
            </div>
            <div className="border-l-4 border-purple-500 pl-4 py-1">
              <h4 className="font-bold text-slate-800">Exceptional Equitable Relief</h4>
              <p className="text-sm text-slate-600 mt-1">E.g., Production injunctions (banning manufacture of tainted products) or mandated code destruction.</p>
            </div>
          </div>
        </div>

        {/* Monetary Damages */}
        <div className="flex-1 bg-white border-2 border-slate-200 rounded-2xl overflow-hidden shadow-sm flex flex-col">
          <div className="bg-slate-100 p-4 border-b border-slate-200 flex items-center gap-3">
            <DollarSign className="text-emerald-600" size={24} />
            <h3 className="font-bold text-lg text-slate-800">2. Monetary Damages</h3>
          </div>
          <div className="p-5 space-y-4 flex-1">
            <div className="border-l-4 border-emerald-400 pl-4 py-1">
              <h4 className="font-bold text-slate-800">Actual Loss</h4>
              <p className="text-sm text-slate-600 mt-1">The plaintiff's lost profits resulting from the misappropriation (often requires expert economic analysis).</p>
            </div>
            <div className="border-l-4 border-emerald-500 pl-4 py-1">
              <h4 className="font-bold text-slate-800">Unjust Enrichment</h4>
              <p className="text-sm text-slate-600 mt-1">The defendant's wrongful gains/profits derived from cheating and avoiding R&D costs.</p>
            </div>
            <div className="border-l-4 border-emerald-600 pl-4 py-1">
              <h4 className="font-bold text-slate-800">Reasonable Royalty</h4>
              <p className="text-sm text-slate-600 mt-1">Used when actual loss/enrichment is too speculative. Simulates a hypothetical licensing negotiation.</p>
            </div>
          </div>
        </div>

      </div>

      {/* Enhanced Damages Section */}
      <div className="max-w-5xl mx-auto">
        <div className="bg-red-50 border border-red-200 rounded-xl p-6 flex flex-col md:flex-row items-center gap-6 shadow-sm">
          <div className="bg-red-100 text-red-600 p-4 rounded-full flex-shrink-0">
            <Gavel size={32} />
          </div>
          <div>
            <h3 className="text-lg font-bold text-red-900 mb-1">3. Enhanced Damages & Fees (For Bad Faith)</h3>
            <p className="text-sm text-red-800 leading-relaxed">
              If the misappropriation is proven to be <strong>"willful and malicious"</strong>, courts may award <strong>Exemplary (Punitive) Damages</strong>—often capping at twice the compensatory amount (effectively allowing treble damages). Courts may also shift <strong>Attorneys' Fees</strong> to the prevailing party to penalize bad-faith litigation or malicious theft.
            </p>
          </div>
        </div>
      </div>

    </div>
  );
}
